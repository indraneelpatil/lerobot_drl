{
    "env": {
        "name": "real_robot",
        "task": "keyboard_control_mvp",
        "fps": 10,
        "robot": {
            "type": "so101_follower",
            "id": "singles_inferno_dex_follower",
            "port": "/dev/ttyACM0",
            "cameras": {
                "top": {
                    "type": "opencv",
                    "index_or_path": 4,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                },
                "wrist": {
                    "type": "opencv",
                    "index_or_path": 8,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                }
            }
        },
        "teleop": {
            "type": "so101_leader_with_interventions",
            "id": "singles_inferno_dex_leader",
            "port": "/dev/ttyACM1"
        },
        "processor": {
            "control_mode": "keyboard",
            "observation": {
                "display_cameras": false,
                "add_joint_velocity_to_observation": false
            },
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0
            },
            "reset": {
                "fixed_reset_joint_positions": [2, -20, -6.7, 100, -49, 1],
                "reset_time_s": 10.0,
                "control_time_s": 300.0,
                "terminate_on_success": true
            },
            "inverse_kinematics": {
                "urdf_path": "../assets/robots/so101.urdf",
                "target_frame_name": "gripper_frame_link",
                "end_effector_bounds": {
                    "max": [0.32, 0.142, 0.20],
                    "min": [0.05, -0.20, 0.01]
                },
                "end_effector_step_sizes": {
                    "x": 0.2,
                    "y": 0.2,
                    "z": 0.2
                }
            },
            "image_preprocessing": {
                "crop_params_dict": {
                  "observation.images.top": [3, 137, 426, 455]
                },
                "resize_size": [128, 128]            
            },
            "max_gripper_pos": 50
        }
    },
    "dataset": {
        "repo_id": "indraneelpatil/new_real_robot_pick_cube1",
        "root": null,
        "task": "Real-SO101-Plug-Charger-20-episodes-v1",
        "num_episodes_to_record": 2,
        "replay_episode": null,
        "push_to_hub": true
    },
    "mode": "record",
    "device": "cuda"
}
