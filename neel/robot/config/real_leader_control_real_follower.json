{
    "env": {
        "name": "real_robot",
        "task": "keyboard_control_mvp",
        "fps": 10,
        "robot": {
            "type": "so101_follower",
            "id": "singles_inferno_dex_follower",
            "port": "/dev/ttyACM0"
        },
        "teleop": {
            "type": "so101_leader_with_interventions",
            "id": "singles_inferno_dex_leader",
            "port": "/dev/ttyACM1"
        },
        "processor": {
            "control_mode": "keyboard",
            "observation": {
                "display_cameras": false,
                "add_joint_velocity_to_observation": false
            },
            "image_preprocessing": null,
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0
            },
            "reset": {
                "fixed_reset_joint_positions": [0.0, 0.0, 0.0, 90.0, 0.0, 30.0],
                "reset_time_s": 10.0,
                "control_time_s": 300.0,
                "terminate_on_success": false
            },
            "inverse_kinematics": {
                "urdf_path": "../assets/robots/so101.urdf",
                "target_frame_name": "gripper_frame_link",
                "end_effector_bounds": {
                    "max": [0.32, 0.142, 0.20],
                    "min": [0.05, -0.20, 0.01]
                },
                "end_effector_step_sizes": {
                    "x": 0.025,
                    "y": 0.025,
                    "z": 0.025
                }
            },
            "max_gripper_pos": 30
        }
    },
    "dataset": {
        "repo_id": "indraneelpatil/isaac_sim_pick_lift_sim8",
        "root": null,
        "task": "RealRobot-SO101-Plug-Charger",
        "num_episodes_to_record": 5,
        "replay_episode": null,
        "push_to_hub": true
    },
    "mode": "record",
    "device": "cuda"
}
