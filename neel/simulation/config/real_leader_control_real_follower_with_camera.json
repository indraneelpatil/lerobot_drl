{
    "env": {
        "name": "real_robot",
        "task": "keyboard_control_mvp",
        "fps": 10,
        "robot": {
            "type": "so101_follower",
            "id": "singles_inferno_dex_follower",
            "port": "/dev/ttyACM0",
            "cameras": {
                "top": {
                    "type": "opencv",
                    "index_or_path": 4,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                },
                "wrist": {
                    "type": "opencv",
                    "index_or_path": 6,
                    "height": 480,
                    "width": 640,
                    "fps": 30
                }
            }
        },
        "teleop": {
            "type": "so101_leader_with_interventions",
            "id": "singles_inferno_dex_leader",
            "port": "/dev/ttyACM1"
        },
        "processor": {
            "control_mode": "keyboard",
            "observation": {
                "display_cameras": false,
                "add_joint_velocity_to_observation": false
            },
            "image_preprocessing": null,
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0
            },
            "reset": {
                "fixed_reset_joint_positions": [-7.14, 11, 95.48, -94.95, -56.44, 2.02],
                "reset_time_s": 2.0,
                "control_time_s": 300.0,
                "terminate_on_success": false
            },
            "inverse_kinematics": {
                "urdf_path": "assets/robots/so101.urdf",
                "target_frame_name": "gripper_frame_link",
                "end_effector_bounds": {
                    "min": [0.195, -0.065, 0.005],
                    "max": [0.25, 0.065, 0.1]
                },
                "end_effector_step_sizes": {
                    "x": 0.025,
                    "y": 0.025,
                    "z": 0.025
                }
            },
            "max_gripper_pos": 30
        }
    },
    "dataset": {
        "repo_id": "brucekimrok/real_robot_plug_charger",
        "root": null,
        "task": "Real-SO101-Plug-Charger-5-episodes-v0",
        "num_episodes_to_record": 5er,
        "replay_episode": null,
        "push_to_hub": true
    },
    "mode": "record",
    "device": "cpu"
}
